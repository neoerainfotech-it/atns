#--------------------------------------------------------------------
# ENVIRONMENT
#--------------------------------------------------------------------
CI_ENVIRONMENT = development
encryption.key = 'ABCDEFGHIJKLMNOPQRSTUVWXYZ123456789'
#--------------------------------------------------------------------
# APP CONFIGURATION
#--------------------------------------------------------------------
app.baseURL = 'http://localhost/ATNA/public/'
app.forceGlobalSecureRequests = false
app.CSPEnabled = false

#--------------------------------------------------------------------
# DATABASE CONFIGURATION
#--------------------------------------------------------------------
database.default.hostname = localhost
database.default.database = atna
database.default.username = root
database.default.password = 
database.default.DBDriver = MySQLi
database.default.DBPrefix = cyb_
database.default.port = 3306

#--------------------------------------------------------------------
# CONFIG CATALOG PATHS
#--------------------------------------------------------------------
CATALOG = 'assets/frontend/'
ADMIN_CATALOG = 'assets/backend/'